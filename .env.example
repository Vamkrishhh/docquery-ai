# Copy this file to .env and fill in your values.
# These variables are statically injected at build time by Vite.
# They MUST be prefixed with VITE_ to be accessible in client-side code.

# Your Supabase Project URL (found in: Project Settings > API)
VITE_SUPABASE_URL=

# Your Supabase Anonymous/Public Key (found in: Project Settings > API)
VITE_SUPABASE_ANON_KEY=

# Add these same keys to Netlify: Site Settings > Environment Variables
# before triggering any production build or deploy.
